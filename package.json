{
  "name": "schooltape",
  "version": "4.5.1",
  "private": true,
  "description": "Schooltape is a free, open-source, web extension that allows you to customise the look, feel, and functionality of Schoolbox!",
  "homepage": "https://schooltape.github.io",
  "license": "MIT",
  "author": "42willow",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "format": "prettier --write .",
    "postinstall": "wxt prepare",
    "lint": "oxlint",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "devDependencies": {
    "@catppuccin/palette": "^1.7.1",
    "@catppuccin/tailwindcss": "1.0.0",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@wxt-dev/module-svelte": "^2.0.4",
    "globals": "^17.4.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semver": "^7.7.4",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "svelte-spa-router": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.0",
    "wxt": "^0.20.19"
  }
}
